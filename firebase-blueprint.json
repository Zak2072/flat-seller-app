{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores basic user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Property": {
      "title": "Property",
      "description": "Stores property-specific information and vault progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Sold"] },
        "vaultProgress": {
          "type": "object",
          "properties": {
            "team": { "type": "boolean" },
            "forms": { "type": "boolean" },
            "money": { "type": "boolean" },
            "safety": { "type": "boolean" },
            "handoff": { "type": "boolean" }
          }
        },
        "vaultFiles": {
          "type": "object",
          "description": "Map of document IDs to file information."
        },
        "aiVerification": {
          "type": "object",
          "description": "Map of document IDs to AI verification results."
        },
        "teamInfo": {
          "type": "object",
          "properties": {
            "solicitor": { "type": "string" },
            "estateAgent": { "type": "string" },
            "managingAgent": { "type": "string" }
          }
        },
        "financialInfo": {
          "type": "object",
          "properties": {
            "reserveFundAmount": { "type": "string" }
          }
        },
        "solicitorInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "sentAt": { "type": "string", "format": "date-time" },
            "shareId": { "type": "string" }
          }
        },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "hasPaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "address", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{uid}/properties/{propertyId}": {
      "schema": "Property",
      "description": "Property-specific data and vault progress."
    }
  }
}
